# Backend Environment Variables

# Server
PORT=3001
HOST=127.0.0.1

# File upload limits (in bytes)
MAX_FILE_SIZE=52428800

# Temporary file storage
TMP_DIR=./tmp

# Output directory
OUTPUT_DIR=./outputs

# Conversion settings
DEFAULT_FPS=30
DEFAULT_BITRATE=500
MAX_COMPRESSION_PASSES=5
MIN_QUALITY=0.5
